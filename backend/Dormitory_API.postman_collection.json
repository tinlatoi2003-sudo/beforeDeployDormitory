            {
              "name": "Create Building",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 201) {",
                      "    var json = pm.response.json();",
                      "    pm.collectionVariables.set('buildingId', json._id);",
                      "    console.log('Saved buildingId:', json._id);",
                      "}"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Tòa A\",\n  \"address\": \"123 Nguyễn Trãi, Quận 5, TP.HCM\",\n  \"totalFloors\": 5,\n  \"description\": \"Tòa nhà ký túc xá A dành cho sinh viên nam\",\n  \"managerId\": \"{{managerId}}\"\n}",
